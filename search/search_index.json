{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"]},"docs":[{"location":"","title":"\u6b22\u8fce\u6765\u5230 WintermelonC \u7684\u7f51\u9875","text":""},{"location":"#zju","title":"ZJU","text":"<p>\u4f60\u53ef\u4ee5\u627e\u5230\u4e00\u4e9b\u8bfe\u7a0b\u7684\u5b66\u4e60\u7b14\u8bb0\u3001\u5b66\u4e60\u8d44\u6599\u7b49\u6709\u7528\u7684\u5185\u5bb9</p>"},{"location":"#\u5927\u5b66\u751f\u751f\u6d3b\u5e38\u8bc6","title":"\u5927\u5b66\u751f\u751f\u6d3b\u5e38\u8bc6","text":"<p>\u65b9\u5c71\u53a8\u5b50 \u8001\u5e08\u5927\u5b66\u751f\u751f\u6d3b\u5e38\u8bc6\u8bfe\u7684\u8bfe\u7a0b\u7b14\u8bb0</p>"},{"location":"common_sense/","title":"\u5927\u5b66\u751f\u751f\u6d3b\u5e38\u8bc6","text":"<p>\u65b9\u5c71\u53a8\u5b50 \u8001\u5e08\u5927\u5b66\u751f\u751f\u6d3b\u5e38\u8bc6\u8bfe\u7684\u8bfe\u7a0b\u7b14\u8bb0</p>"},{"location":"common_sense/medical_insurance/","title":"\u533b\u4fdd","text":""},{"location":"common_sense/medical_insurance/#1-\u533b\u4fdd\u7c7b\u578b","title":"1 \u533b\u4fdd\u7c7b\u578b","text":""},{"location":"common_sense/medical_insurance/#11-\u57ce\u4e61\u5c45\u6c11\u57fa\u672c\u533b\u7597\u4fdd\u9669","title":"1.1 \u57ce\u4e61\u5c45\u6c11\u57fa\u672c\u533b\u7597\u4fdd\u9669","text":"<p>\u539f\u65b0\u519c\u5408\u4e0e\u57ce\u9547\u5c45\u6c11\u533b\u7597\u4fdd\u9669\u5408\u5e76\u800c\u6210\u3002\u4e3b\u8981\u662f\u9762\u5411\u975e\u6b63\u5f0f\u5c31\u4e1a\u4eba\u5458\u3001\u5b66\u751f\u4ee5\u53ca\u519c\u6751\u5730\u533a\u7684\u5c45\u6c11\u3002\u7531\u653f\u5e9c\u8865\u8d34\u548c\u4e2a\u4eba\u7f34\u8d39\u5171\u540c\u6784\u6210\u57fa\u91d1\u6c60\u3002\u53ef\u4ee5\u9009\u62e9\u7f34\u6216\u8005\u4e0d\u7f34</p>"},{"location":"common_sense/medical_insurance/#\u7f34\u7eb3\u8981\u6c42","title":"\u7f34\u7eb3\u8981\u6c42","text":"<p>\u6bcf\u5e74\u4e2a\u4eba\u81ea\u884c\u7f34\u7eb3</p>"},{"location":"common_sense/medical_insurance/#\u9762\u5411\u5bf9\u8c61","title":"\u9762\u5411\u5bf9\u8c61","text":"<p>\u65e0\u6b63\u5f0f\u5de5\u4f5c\u6216\u672a\u5c31\u4e1a\u7684\u57ce\u4e61\u5c45\u6c11</p>"},{"location":"common_sense/medical_insurance/#\u62a5\u9500\u89c4\u5219","title":"\u62a5\u9500\u89c4\u5219","text":"<p>\u95e8\u8bca\u3001\u4f4f\u9662\u6309\u7167\u5f53\u5730\u89c4\u5b9a \u4e00\u5b9a\u6bd4\u4f8b \u62a5\u9500\uff0c\u5747\u6709 \u8d77\u4ed8\u7ebf \u548c \u5c01\u9876\u7ebf \uff0c\u5e74\u5ea6 \u533b\u7597\u4fdd\u9669\u91d1\u989d\u4e5f\u6709\u5c01\u9876\u7ebf</p> \u8d77\u4ed8\u7ebf - \u60c5\u5f621 <p>\u5047\u8bbe\u5728\u67d0\u5730\u533a\u5c45\u6c11\u533b\u4fdd\u8d77\u4ed8\u7ebf\u4e3a \\(500\\) \u5143 \u5c0f\u660e\u56e0\u4e3a\u54b3\u55fd\u53bb\u793e\u533a\u536b\u751f\u670d\u52a1\u4e2d\u5fc3\u770b\u95e8\u8bca (1) \uff0c\u82b1\u8d39\u4e86 \\(300\\) \u5143\u3002\u7531\u4e8e\u672a\u8fbe\u5230\u8d77\u4ed8\u7ebf\uff0c\u8fd9\u90e8\u5206\u8d39\u7528\u9700\u5c0f\u660e\u81ea\u5df1\u627f\u62c5\uff0c\u4e0d\u80fd\u901a\u8fc7\u5c45\u6c11\u533b\u4fdd\u62a5\u9500</p> <ol> <li>\u95e8\u8bca\u6309\u5e74\u7d2f\u8ba1\uff0c\u6bd4\u5982\u7b2c\u4e00\u6b21\u82b1\u4e86 \\(300\\) \uff0c\u6ca1\u5230\u8d77\u4ed8\u7ebf\uff0c \u7b2c\u4e8c\u6b21\u82b1\u4e86 \\(300\\) \uff0c\u603b\u5171 \\(600\\) \uff0c\u8fbe\u5230\u4e86\u8d77\u4ed8\u7ebf\uff0c\u53ef\u4ee5\u62a5\u4e0a\u53bb</li> </ol> \u8d77\u4ed8\u7ebf - \u60c5\u5f622 <p>\u5047\u8bbe\u5728\u67d0\u5730\u533a\u5c45\u6c11\u533b\u4fdd\u8d77\u4ed8\u7ebf\u4e3a \\(500\\) \u5143 \u5c0f\u7ea2\u56e0\u6025\u6027\u80a0\u80c3\u708e\u4f4f\u9662\uff0c\u6b64\u6b21\u4f4f\u9662\u603b\u8d39\u7528\u4e3a \\(2000\\) \u5143\u3002\u5728\u8ba1\u7b97\u533b\u4fdd\u62a5\u9500\u91d1\u989d\u65f6\uff0c\u5148\u6263\u9664\u8d77\u4ed8\u7ebf \\(500\\) \u5143\uff0c\u53ea\u6709\u8d85\u51fa\u8d77\u4ed8\u7ebf\u7684\u90e8\u5206\uff08 \\(2000-500=1500\\) \u5143\uff09\u624d\u8fdb\u5165\u5c45\u6c11\u533b\u4fdd\u62a5\u9500\u8303\u56f4\u518d\u6839\u636e\u62a5\u9500\u6bd4\u4f8b\u8fdb\u884c\u62a5\u9500\uff0c\u5047\u5982\u62a5\u9500\u6bd4\u4f8b\u662f \\(50\\%\\) \uff0c\u90a3\u5c0f\u7ea2\u62a5\u9500\u91d1\u989d\u4e3a \\(1500 \\times 50\\% = 750\\) \u5143\uff0c\u81ea\u5df1\u9700\u8981\u4ed8 \\(1250\\) \u5143</p> \u5c01\u9876\u7ebf - \u60c5\u5f623 <p>\u5047\u8bbe\u5728\u67d0\u5730\u533a\u5c45\u6c11\u533b\u4fdd\u8d77\u4ed8\u7ebf\u4e3a \\(500\\) \u5143\uff0c\u5c01\u9876\u7ebf\u4e3a \\(2000\\) \u5143 \u5c0f\u521a\u60a3\u4e86\u4e00\u79cd\u8f83\u4e3a\u4e25\u91cd\u7684\u6162\u6027\u75c5\uff0c\u4e00\u5e74\u4e2d\u591a\u6b21\u5c31\u533b\uff0c\u7d2f\u8ba1\u533b\u7597\u8d39\u7528\u8fbe\u5230\u4e86 \\(1800\\) \u5143\u3002\u5728\u4e0d\u8d85\u8fc7\u5c01\u9876\u7ebf\u7684\u60c5\u51b5\u4e0b\uff0c\u5148\u6263\u9664\u8d77\u4ed8\u7ebf \\(500\\) \u5143\uff0c\u5373 \\(1800 - 500 = 1300\\) \u5143\uff0c\u6309 \\(50\\%\\) \u62a5\u9500\u6bd4\u4f8b\u8ba1\u7b97\uff0c\u62a5\u9500\u91d1\u989d\u4e3a \\(1300 \\times 50\\% = 650\\) \u5143\u3002\u5c0f\u521a\u81ea\u5df1\u627f\u62c5\u7684\u8d39\u7528\u4e3a \\(1800 - 650 = 1150\\) \u5143</p> \u5c01\u9876\u7ebf - \u60c5\u5f624 <p>\u5047\u8bbe\u5728\u67d0\u5730\u533a\u5c45\u6c11\u533b\u4fdd\u8d77\u4ed8\u7ebf\u4e3a \\(500\\) \u5143\uff0c\u5c01\u9876\u7ebf\u4e3a \\(2000\\) \u5143 \u5c0f\u5f3a\u4e0d\u5e78\u60a3\u4e0a\u91cd\u5927\u75be\u75c5\uff0c\u533b\u7597\u8d39\u7528\u9ad8\u8fbe \\(2500\\) \u5143\u3002\u7531\u4e8e\u8d85\u8fc7\u4e86\u5c01\u9876\u7ebf \\(2000\\) \u5143\uff0c\u90a3\u4e48\u8d85\u51fa\u7684\u90e8\u5206\u4e3a \\(2500 - 2000 = 500\\) \u5143\u9700\u8981\u5c0f\u5f3a\u81ea\u5df1\u60f3\u529e\u6cd5\u89e3\u51b3\u3002\u672a\u8d85\u51fa\u5c01\u9876\u7ebf\u7684\u90e8\u5206\uff0c\u5148\u6263\u9664\u8d77\u4ed8\u7ebf \\(500\\) \u5143\u540e\u4e3a \\(2000 - 500 = 1500\\) \u5143\u6309 \\(50\\%\\) \u62a5\u9500\u6bd4\u4f8b\u8ba1\u7b97\uff0c\u53ef\u62a5\u9500\u91d1\u989d\u4e3a \\(1500 \\times 50\\% = 750\\) \u5143</p>"},{"location":"common_sense/medical_insurance/#12-\u57ce\u9547\u804c\u5de5\u57fa\u672c\u533b\u7597\u4fdd\u9669","title":"1.2 \u57ce\u9547\u804c\u5de5\u57fa\u672c\u533b\u7597\u4fdd\u9669","text":"<p>\u4e3b\u8981\u9762\u5411\u57ce\u5e02\u4e2d\u7684\u5728\u804c\u5458\u5de5\u548c\u9000\u4f11\u4eba\u5458\u3002\u4e2a\u4eba\u548c\u96c7\u4e3b\u5171\u540c\u7f34\u7eb3\u4fdd\u9669\u8d39\uff0c\u53c2\u4fdd\u4eba\u5728\u5c31\u533b\u65f6\u53ef\u4ee5\u4eab\u53d7\u4e00\u5b9a\u7684\u62a5\u9500\u6bd4\u4f8b</p> <p>\u4e94\u9669\u4e00\u91d1</p> <p>\u6211\u4eec\u5728\u627e\u5de5\u4f5c\u65f6\uff0c\u5e38\u8bf4\u7684 \u4e94\u9669\u4e00\u91d1 (1) \u5176\u4e2d\u7684\u533b\u7597\u4fdd\u9669\u5c31\u5c5e\u4e8e\u8fd9\u4e00\u7c7b\u3002\u4f01\u4e1a\u4e0e\u4f60\u7b7e\u8ba2\u52b3\u52a8\u5173\u7cfb\u65f6\uff0c\u4e00\u5b9a\u8981\u4e3a\u4f60\u7f34\u7684</p> <ol> <li>\u57fa\u672c\u517b\u8001\u4fdd\u9669\u3001\u57fa\u672c\u533b\u7597\u4fdd\u9669\u3001\u5931\u4e1a\u4fdd\u9669\u3001\u5de5\u4f24\u4fdd\u9669\u3001\u751f\u80b2\u4fdd\u9669\u4ee5\u53ca\u4f4f\u623f\u516c\u79ef\u91d1</li> </ol>"},{"location":"common_sense/medical_insurance/#\u7f34\u7eb3\u8981\u6c42_1","title":"\u7f34\u7eb3\u8981\u6c42","text":"<p>\u516c\u53f8\u6bcf\u6708\u7f34\u7eb3</p>"},{"location":"common_sense/medical_insurance/#\u9762\u5411\u5bf9\u8c61_1","title":"\u9762\u5411\u5bf9\u8c61","text":"<p>\u4f01\u4e8b\u4e1a\u5355\u4f4d\u5728\u804c\u5458\u5de5</p>"},{"location":"common_sense/medical_insurance/#\u62a5\u9500\u89c4\u5219_1","title":"\u62a5\u9500\u89c4\u5219","text":"<p>\u95e8\u8bca\u3001\u4f4f\u9662\u6309\u7167\u5f53\u5730\u89c4\u5b9a \u4e00\u5b9a\u6bd4\u4f8b \u62a5\u9500\uff0c\u5747\u6709 \u8d77\u4ed8\u7ebf \u548c \u5c01\u9876\u7ebf \uff0c\u5e74\u5ea6 \u533b\u4fdd\u62a5\u9500\u91d1\u989d\u4e5f\u6709\u5c01\u9876\u7ebf (\u5747\u9ad8\u4e8e\u5c45\u6c11\u533b\u4fdd)</p> <p>\u4e2a\u4eba\u8d26\u6237</p> <ul> <li>\u6765\u6e90\uff1a\u804c\u5de5\u4e2a\u4eba\u7f34\u7eb3\u90e8\u5206\uff08\u6bcf\u6708\u5de5\u8d44\u6263\u51cf\uff09 + \u90e8\u5206\u516c\u53f8\u7f34\u7eb3 + \u5229\u606f\u6536\u5165 (1)</li> <li>\u7528\u4e8e\u652f\u4ed8\u533b\u4fdd\u8303\u56f4\u5185\u9700\u8981\u4e2a\u4eba\u652f\u4ed8\u90e8\u5206\u7684\u8d39\u7528\uff0c\u8fd8\u53ef\u7528\u4e8e\u836f\u5e97\u4e70\u836f\u53ca\u5546\u4e1a\u4fdd\u9669</li> <li>\u4e13\u6b3e\u4e13\u7528 (2)\u3001\u79ef\u7d2f\u4f7f\u7528\u3001\u7ee7\u627f\u6027</li> </ul> <ol> <li>\u50cf\u628a\u94b1\u5b58\u94f6\u884c\u4e00\u6837\uff0c\u6bcf\u5e74\u4f1a\u6709\u4e00\u5b9a\u7684\u5229\u606f\u4ea7\u751f</li> <li>\u53ea\u80fd\u7528\u4e8e\u533b\u7597\u65b9\u9762</li> </ol>"},{"location":"common_sense/medical_insurance/#2-\u533b\u4fdd\u8d26\u6237","title":"2 \u533b\u4fdd\u8d26\u6237","text":"<p>\u67e5\u770b\u81ea\u5df1\u7684\u533b\u4fdd\u8d26\u6237</p> \u5fae\u4fe1\u652f\u4ed8\u5b9d <p>\u641c\u7d22 \u56fd\u5bb6\u533b\u4fdd\u670d\u52a1\u5e73\u53f0 \u5c0f\u7a0b\u5e8f\uff0c\u9996\u6b21\u4f7f\u7528\u9700\u5b9e\u540d\u8ba4\u8bc1\u767b\u5f55 </p> <p>\u641c\u7d22 \u56fd\u5bb6\u533b\u4fdd\u670d\u52a1\u5e73\u53f0 \u5c0f\u7a0b\u5e8f\uff0c\u9996\u6b21\u4f7f\u7528\u9700\u5b9e\u540d\u8ba4\u8bc1\u767b\u5f55 </p>"},{"location":"common_sense/medical_insurance/#3-\u533b\u4fdd\u62a5\u9500","title":"3 \u533b\u4fdd\u62a5\u9500","text":"<p>\u901a\u5e38\uff0c\u95e8\u8bca\u6309\u5e74\u7d2f\u8ba1\u5c31\u8bca\u91d1\u989d\uff0c\u4f4f\u9662\u5355\u6b21\u5c31\u8bca\u91d1\u989d</p>"},{"location":"common_sense/medical_insurance/#31-\u62a5\u9500\u8303\u56f4","title":"3.1 \u62a5\u9500\u8303\u56f4","text":"<p>\u5305\u62ec \u836f\u54c1\u8d39 \u3001\u8bca\u7597\u8d39 \u3001\u4f4f\u9662\u8d39 \u7b49\uff0c\u5177\u4f53\u4f9d\u533b\u4fdd\u79cd\u7c7b\u548c\u653f\u7b56\u800c\u5b9a\u3002\u9700\u5728 \u5b9a\u70b9\u533b\u7597\u673a\u6784 \u5c31\u8bca\uff0c\u4e14\u533b\u7597\u9879\u76ee\u9700 \u7b26\u5408\u533b\u4fdd\u76ee\u5f55 \u89c4\u5b9a</p>"},{"location":"common_sense/medical_insurance/#32-\u4f7f\u7528\u65b9\u6cd5","title":"3.2 \u4f7f\u7528\u65b9\u6cd5","text":"<p>\u6253\u5f00\u4e8c\u7ef4\u7801\u5373\u53ef\u4f7f\u7528\uff0c\u5728\u6240\u6709\u7f34\u8d39\u73af\u8282\u8bf4\u660e\u4f7f\u7528\u533b\u4fdd\u652f\u4ed8\uff08\u673a\u5668\u81ea\u52a9\u7f34\u8d39\u4e5f\u53ef\u9009\u62e9\u7535\u5b50\u533b\u4fdd\u5361\u652f\u4ed8\uff09</p> \u5fae\u4fe1 <p> </p>"},{"location":"common_sense/medical_insurance/#\u6302\u53f7\u533b\u4fdd\u62a5\u9500","title":"\u6302\u53f7\u533b\u4fdd\u62a5\u9500","text":"<p>\u7ebf\u4e0a\u6302\u53f7\u6709\u65f6\u4f1a\u76f4\u63a5\u7f34\u8d39\uff0c\u9700\u8981\u7528\u7ed1\u5b9a\u4e86\u533b\u4fdd\u7684\u5c31\u8bca\u5361\u6302\u53f7\u624d\u80fd\u62a5\u9500\uff0c\u6216\u8005\u65e0\u6cd5\u62a5\u9500</p> <p>\u533b\u9662\u73b0\u573a\u5237\u7535\u5b50\u533b\u4fdd\u7f34\u8d39\u65f6\uff0c\u5982\u679c\u662f\u5c45\u6c11\u533b\u4fdd\u9700\u8981\u7f34\u7eb3\u4e2a\u4eba\u90e8\u5206\uff0c\u5982\u679c\u662f\u804c\u5de5\u533b\u4fdd\u4f1a\u81ea\u52a8\u4ece\u4e2a\u4eba\u8d26\u6237\u4e2d\u6263\u9664\u9700\u4e2a\u4eba\u7f34\u7eb3\u90e8\u5206</p> <p>\u5982\u679c\u53d1\u73b0\u7f34\u7eb3\u7684\u662f\u5b8c\u5168\u6ca1\u6709\u62a5\u9500\u7684\u91d1\u989d\u53ef\u80fd:</p> <ol> <li>\u5e74\u5ea6\u7d2f\u8ba1\u95e8\u8bca\u8d39\u7528\u672a\u8fbe\u5230\u8d77\u4ed8\u7ebf</li> <li>\u90e8\u5206\u5730\u533a\u7684\u6302\u53f7\u8d39\u4e0d\u652f\u6301\u533b\u4fdd\u62a5\u9500</li> <li>\u90e8\u5206\u5730\u533a\u7684\u7ebf\u4e0a\u6302\u53f7\u65e0\u6cd5\u62a5\u9500\uff08\u5c3d\u91cf\u73b0\u573a\u6302\u53f7\uff09\uff08\u6302\u53f7\u65f6\u7528\u533b\u4fdd\u5361\u3001\u7535\u5b50\u533b\u4fdd\u8eab\u4efd\uff09</li> </ol>"},{"location":"common_sense/medical_insurance/#\u68c0\u67e5\u4e70\u836f\u533b\u4fdd\u62a5\u9500","title":"\u68c0\u67e5\u4e70\u836f\u533b\u4fdd\u62a5\u9500","text":"<p>\u6240\u6709\u7f34\u8d39\u73af\u8282\u5747\u51fa\u793a\u533b\u4fdd\u5361\u6216\u7535\u5b50\u533b\u4fdd\u5373\u53ef</p>"},{"location":"common_sense/medical_insurance/#\u4f4f\u9662\u533b\u4fdd\u62a5\u9500","title":"\u4f4f\u9662\u533b\u4fdd\u62a5\u9500","text":"<p>\u4f4f\u9662\u9700\u8981\u63d0\u524d\u9884\u5b58\u4f4f\u9662\u91d1\uff0c\u4f4f\u9662\u53d1\u751f\u7684\u8d39\u7528\u7cfb\u7edf\u4f1a\u6839\u636e\u533b\u4fdd\u4fe1\u606f\uff0c\u81ea\u884c\u5b8c\u6210\u62a5\u9500\u6263\u51cf\uff0c\u975e\u62a5\u9500\u90e8\u5206\u5728\u9884\u5b58\u91d1\u4e2d\u6263\u9664\uff0c\u9884\u5b58\u91d1\u6263\u9664\u7684\u94b1\u65e0\u6cd5\u62a5\u9500\uff0c\u5982\u4e0d\u5728\u533b\u4fdd\u62a5\u9500\u8303\u56f4\u5185\u7684\u68c0\u67e5\u6216\u7528\u836f\uff0c\u5269\u4f59\u7684\u94b1\u51fa\u9662\u65f6\u8fdb\u884c\u9000\u6b3e\u5373\u53ef</p>"},{"location":"common_sense/medical_insurance/#33-\u603b\u7ed3","title":"3.3 \u603b\u7ed3","text":"<p>\u533b\u9662\u6302\u53f7\u5c3d\u91cf\u9009\u7ebf\u4e0b</p> <p>\u65e0\u8bba\u4ec0\u4e48\u8d39\u7528\u5148\u9009\u533b\u4fdd\u5361\u652f\u4ed8\uff0c\u5237\u4e0d\u52a8\u518d\u4e2a\u4eba\u652f\u4ed8</p> <p>\u5404\u5730\u653f\u7b56\u4e0d\u540c\uff0c\u9700\u8981\u81ea\u884c\u4e86\u89e3\u5f53\u5730\u89c4\u5219</p>"},{"location":"common_sense/medical_insurance/#4-\u4eb2\u60c5\u8d26\u6237\u5bb6\u5ead\u5171\u6d4e","title":"4 \u4eb2\u60c5\u8d26\u6237/\u5bb6\u5ead\u5171\u6d4e","text":"<p>\u5982\u679c\u4f60\u662f\u804c\u5de5\u533b\u4fdd\uff0c\u4e2a\u4eba\u8d26\u6237\u4f59\u989d\u81ea\u5df1\u82b1\u4e0d\u5b8c\uff0c\u53ef\u4ee5\u529e\u7406\u3002\u524d\u63d0\u662f\u88ab\u4f9b\u7ed9\u8005\u4e5f\u53c2\u52a0\u533b\u4fdd\uff08\u76ee\u524d\u4e0d\u591f\u5b8c\u5584\uff0c\u5927\u90e8\u5206\u5730\u533a\u53ea\u80fd\u7701\u5185\u529e\u7406\uff09</p>"},{"location":"common_sense/medical_insurance/#41-\u533a\u522b","title":"4.1 \u533a\u522b","text":"<ul> <li>\u4eb2\u60c5\u8d26\u6237\uff1a\u5e2e\u5bb6\u4eba\u5c55\u793a\u533b\u4fdd\u7801</li> <li>\u5bb6\u5ead\u5171\u6d4e\uff1a\u628a\u81ea\u5df1\u7684\u533b\u4fdd\u4e2a\u8d26\u989d\u5ea6\u5171\u6d4e\u7ed9\u5bb6\u4eba</li> </ul>"},{"location":"common_sense/medical_insurance/#42-\u529e\u7406\u65b9\u5f0f","title":"4.2 \u529e\u7406\u65b9\u5f0f","text":"\u5fae\u4fe1\u652f\u4ed8\u5b9d"},{"location":"common_sense/medical_insurance/#5-\u5927\u5b66\u751f\u533b\u4fdd","title":"5 \u5927\u5b66\u751f\u533b\u4fdd","text":"<p>\u5982\u679c\u6709\u8f6c\u5b66\u3001\u4f11\u5b66\u3001\u4ea4\u6362\u751f\u3001\u5e94\u5f81\u5165\u4f0d\u7b49\u60c5\u51b5\uff0c\u5982\u679c\u4fdd\u7559\u5b66\u7c4d\u3001\u533b\u4fdd\u6b63\u5e38\u5728\u7f34\u7684\u8bdd\u4f9d\u65e7\u53ef\u4ee5\u4eab\u53d7\u5927\u5b66\u751f\u533b\u4fdd\u5f85\u9047</p> <p>\u5927\u5b66\u751f\u4f7f\u7528\u65f6\u5206\u4e3a\u4f4f\u9662\u548c\u95e8\u8bca\u4e24\u90e8\u5206\uff0c\u5728\u7701\u5185\u533b\u4fdd\u5b9a\u70b9\u533b\u9662\u4f4f\u9662\u65f6\uff0c\u5728\u4f4f\u9662\u90e8\u7f34\u8d39\u7a97\u53e3\u51fa\u793a\u672c\u4eba\u7684\u8eab\u4efd\u8bc1\u6216\u8005\u7535\u5b50\u533b\u4fdd\u51ed\u8bc1\u53ef\u76f4\u63a5\u7ed3\u7b97</p>"},{"location":"common_sense/medical_insurance/#51-\u95e8\u8bca","title":"5.1 \u95e8\u8bca","text":"<p>\u7531\u53c2\u4fdd\u5927\u5b66\u751f\u643a\u5e26\u8eab\u4efd\u8bc1\u5230 \u6821\u533b\u9662 (1) \u8fdb\u884c\u6cbb\u7597\u3002\u53d1\u751f\u7684\u533b\u7597\u8d39\u7528\u7531\u95e8\u8bca\u7edf\u7b79\u57fa\u91d1\u6309\u4e00\u5b9a\u7684\u6bd4\u4f8b\u62a5\u9500\uff0c\u6bcf\u5b66\u5e74\u6700\u9ad8\u652f\u4ed8\u6709\u9650\u989d\u3002\u56e0\u75c5\u60c5\u9700\u8981\u786e\u9700 \u8f6c\u8bca \u7684\uff0c\u7531\u6821\u533b\u9662\u7684\u63a5\u8bca\u533b\u5e08\u5f00\u5177\u8f6c\u8bca\u5355\u5e76\u7ecf\u6821\u533b\u9662\u76d6\u7ae0\u540c\u610f\u540e\u8f6c\u5f80\u5176\u5b83\u533b\u4fdd\u5b9a\u70b9\u533b\u9662\u5c31\u533b\u3002\u8f6c\u8bca\u540e\u7684\u95e8\u8bca\u533b\u7597\u8d39\u7528\u5148\u7531\u60a3\u8005\u4e2a\u4eba\u57ab\u4ed8\u8f6c\u8bca\u540e\u51ed\u8f6c\u8bca\u533b\u9662\u7684\u5404\u9879\u7968\u636e\u3001\u8f6c\u8bca\u5355\uff0c\u5230\u6821\u533b\u9662\u7f34\u8d39\u7a97\u53e3\u8fdb\u884c\u62a5\u9500\uff08\u90e8\u5206\u5730\u533a\u53ef\u80fd\u53ef\u4ee5\u76f4\u63a5\u4f7f\u7528\uff0c\u9700\u540c\u5b66\u4eec\u81ea\u884c\u4e86\u89e3\u5f53\u5730\u653f\u7b56\uff09</p> <ol> <li>\u6240\u6709\u7684\u533b\u4fdd\u9700\u8981\u5728\u5b9a\u70b9\u533b\u9662\u4f7f\u7528\uff0c\u53ea\u4e0d\u8fc7\u5927\u5b66\u751f\u7684\u5b9a\u70b9\u533b\u9662\u5c31\u662f\u6821\u533b\u9662</li> </ol> <p>\u82e5\u6709\u5bd2\u6691\u5047\u7b49\u4e0d\u5728\u5e02\u5185\u65e0\u6cd5\u524d\u5f80\u6821\u533b\u9662\u5148\u884c\u6cbb\u7597\u7684\u60c5\u51b5\uff0c\u524d\u5f80\u533b\u4fdd\u5b9a\u70b9\u533b\u9662\u8fdb\u884c\u95e8\u8bca\u6cbb\u7597 (1) \uff0c\u81ea\u884c\u57ab\u4ed8\u533b\u836f\u8d39\u5e76\u4fdd\u5b58\u597d\u533b\u7597\u8d39\u7528\u7968\u636e\u3001\u8bca\u65ad\u8bc1\u660e\u3001\u95e8\u8bca\u75c5\u5386\u3001\u68c0\u67e5\u5316\u9a8c\u62a5\u544a\u5355\u3001\u95e8\u8bca\u6536\u8d39\u660e\u7ec6\uff0c\u8fd4\u6821\u540e\u5230\u6821\u533b\u9662\u7f34\u8d39\u7a97\u53e3\u8fdb\u884c\u62a5\u9500</p> <ol> <li>\u6700\u597d\u529e\u7406\u5f02\u5730\u5c31\u8bca</li> </ol>"},{"location":"common_sense/medical_insurance/#52-\u5f02\u5730\u5c31\u8bca","title":"5.2 \u5f02\u5730\u5c31\u8bca","text":"<p>\u5728\u5916\u7701\u671f\u95f4\u7a81\u53d1\u6025\u75c7\u5728\u5f53\u5730\u5c31\u8fd1\u6cbb\u7597\u7684\u540c\u5b66\uff0c\u5e94\u5728\u5165\u9662\u4e4b\u524d\u8fdb\u884c\u5f02\u5730\u5c31\u533b\u5907\u6848\uff0c\u5907\u6848\u6210\u529f\u540e\uff0c\u5728\u5f53\u5730\u5f00\u901a\u5f02\u5730\u7ed3\u7b97\u7684\u533b\u9662\u5c31\u533b\uff0c\u51fa\u9662\u540e\u76f4\u63a5\u7ed3\u7b97</p>"},{"location":"common_sense/medical_insurance/#\u529e\u7406\u65b9\u5f0f","title":"\u529e\u7406\u65b9\u5f0f","text":"\u5fae\u4fe1\u652f\u4ed8\u5b9d"},{"location":"zju/","title":"ZJU","text":"<p>\u4f60\u53ef\u4ee5\u627e\u5230\u4e00\u4e9b\u8bfe\u7a0b\u7684\u5b66\u4e60\u7b14\u8bb0\u3001\u5b66\u4e60\u8d44\u6599\u7b49\u6709\u7528\u7684\u5185\u5bb9</p>"},{"location":"zju/basic_courses/","title":"\u4e13\u4e1a\u57fa\u7840\u8bfe\u7a0b","text":"<p>\u6982\u7387\u8bba\u4e0e\u6570\u7406\u7edf\u8ba1</p>"},{"location":"zju/basic_courses/prob_theo_and_math_stat/","title":"\u6982\u7387\u8bba\u4e0e\u6570\u7406\u7edf\u8ba1","text":"<p>2 \u968f\u673a\u53d8\u91cf\u53ca\u5176\u6982\u7387\u5206\u5e03</p>"},{"location":"zju/basic_courses/prob_theo_and_math_stat/chapter_2/","title":"\u968f\u673a\u53d8\u91cf\u53ca\u5176\u6982\u7387\u5206\u5e03","text":"<p>\u8bf4\u660e</p> <p>\u6b64\u6587\u6863\u6b63\u5728\u66f4\u65b0\u4e2d\u2026\u2026</p>"},{"location":"zju/basic_courses/prob_theo_and_math_stat/chapter_2/#3-\u968f\u673a\u53d8\u91cf\u7684\u6982\u7387\u5206\u5e03\u51fd\u6570","title":"3 \u968f\u673a\u53d8\u91cf\u7684\u6982\u7387\u5206\u5e03\u51fd\u6570","text":""},{"location":"zju/basic_courses/prob_theo_and_math_stat/chapter_2/#31-\u5b9a\u4e49","title":"3.1 \u5b9a\u4e49","text":"<p>\u8bbe \\(X\\) \u4e3a\u4e00\u968f\u673a\u53d8\u91cf\uff0c \\(x\\) \u4e3a\u4efb\u610f\u5b9e\u6570\uff0c\u51fd\u6570 $$ F(x) = P \\lbrace X \\leqslant x \\rbrace $$ \u79f0\u4e3a\u968f\u673a\u53d8\u91cf \\(X\\) \u7684 \u6982\u7387\u5206\u5e03\u51fd\u6570 \uff0c\u7b80\u79f0 \u5206\u5e03\u51fd\u6570</p> <p>\u51e0\u4f55\u610f\u4e49</p> <p>\\(F(x)\\) \u7684\u51e0\u4f55\u610f\u4e49\uff1a   \u5c06 \\(X\\) \u8bbe\u60f3\u6210\u4e00\u968f\u673a\u70b9\uff0c\u90a3\u4e48 \\(X\\) \u843d\u5728\u533a\u95f4 \\((- \\infty, x]\\) \u4e0a\u7684\u6982\u7387\u5373\u4e3a \\(F(x)\\)</p> <p>\u5bf9\u4efb\u610f\u7684\u5b9e\u6570 \\(x_1, x_2 ( x_1 &lt; x_2 )\\) \uff0c\u6709 $$ P \\lbrace x_1 &lt; X \\leqslant x_2 \\rbrace = P \\lbrace X \\leqslant x_2 \\rbrace - P \\lbrace X \\leqslant x_1 \\rbrace = F ( x_2 ) -  F ( x_1 ) $$</p>"},{"location":"zju/basic_courses/prob_theo_and_math_stat/chapter_2/#32-\u6027\u8d28","title":"3.2 \u6027\u8d28","text":"<ol> <li>\\(0 \\leqslant F(x) \\leqslant 1\\)\uff0c\u4e14\u6709 \\(F(-\\infty) = 0, F(+\\infty) = 1\\)</li> <li>\\(F(x)\\) \u5355\u8c03\u4e0d\u51cf    \u5f53 \\(x_2 &gt; x_1\\) \u65f6\uff0c \\(F(x_2) - F(x_1) = P \\lbrace x_1 &lt; X \\leqslant x_2 \\rbrace \\geqslant 0\\)\uff0c \u56e0\u6b64 \\(F(x_2) \\geqslant F(x_1)\\)</li> <li>\\(F(x)\\) \u53f3\u8fde\u7eed\uff0c\u5373 \\(F(x + 0) = F(x)\\)</li> <li>\\(F(x) - F(x - 0) = P \\lbrace X = x \\rbrace\\)</li> </ol>"},{"location":"zju/general_courses/","title":"\u901a\u8bc6\u8bfe\u7a0b","text":""},{"location":"zju/general_courses/#\u519b\u4f53\u7c7b","title":"\u519b\u4f53\u7c7b","text":"<p>\u65e0\u7ebf\u7535\u6d4b\u5411\uff08\u521d\u7ea7\uff09</p>"},{"location":"zju/general_courses/#\u81ea\u7136\u79d1\u5b66\u901a\u8bc6\u7c7b","title":"\u81ea\u7136\u79d1\u5b66\u901a\u8bc6\u7c7b","text":"<p>\u5927\u5b66\u7269\u7406\u5b9e\u9a8c</p>"},{"location":"zju/general_courses/#\u521b\u65b0\u521b\u4e1a\u7c7b","title":"\u521b\u65b0\u521b\u4e1a\u7c7b","text":"<p>\u521b\u4e1a\u542f\u7a0b</p>"},{"location":"zju/general_courses/#\u901a\u8bc6\u9009\u4fee\u8bfe\u7a0b","title":"\u901a\u8bc6\u9009\u4fee\u8bfe\u7a0b","text":"<p>\u8336\u6587\u5316\u4e0e\u8336\u5065\u5eb7</p>"},{"location":"zju/general_courses/entrepreneurship/","title":"\u521b\u4e1a\u542f\u7a0b","text":""},{"location":"zju/general_courses/entrepreneurship/#\u8bfe\u7a0b\u4ecb\u7ecd","title":"\u8bfe\u7a0b\u4ecb\u7ecd","text":"<p>\u6ce8\u610f</p> <p>\u6b64\u4e3a 2023-2024 \u590f\u5b66\u671f\u8bfe\u7a0b\u5b89\u6392\uff0c\u4ec5\u4f9b\u53c2\u8003</p> <p>lh\u8001\u5e08</p> <p>\u7b2c\u4e00\u8282\u8bfe\u4e3a\u5bfc\u8bfb\u8bfe\uff0c\u53bb\u6559\u5ba4\u4e0a\u8bfe\uff0c\u4ecb\u7ecd\u672c\u8bfe\u7a0b\u7684\u6559\u5b66\u5f62\u5f0f\u3001\u65f6\u95f4\u5b89\u6392\u3001\u8003\u8bd5\u7b49\u5185\u5bb9\u3002\u4e4b\u540e\u7684\u8bfe\u90fd\u53ef\u4ee5\u4e0d\u7528\u53bb\u6559\u5ba4</p>"},{"location":"zju/general_courses/entrepreneurship/#\u8bfe\u7a0b\u5185\u5bb9","title":"\u8bfe\u7a0b\u5185\u5bb9","text":"<p>\u6ce8\u610f</p> <p>\u4ec5\u7f57\u5217\u8bfe\u672c (1) \u7eea\u8bba + 1-7\u7ae0 \u5185\u5bb9</p> <ol> <li>\u300a\u521b\u4e1a\u7ba1\u7406\u5b66\u300b\u7b2c2\u7248\u5f20\u5e0f \u59dc\u5f66\u798f \u4e3b\u7f16\u6e05\u534e\u5927\u5b66\u51fa\u7248\u793e</li> </ol> <ol> <li>\u7eea\u8bba     <ol> <li>\u521b\u4e1a\u7684\u7406\u60f3\u548c\u5b9e\u73b0</li> <li>\u521b\u4e1a\u51b3\u7b56\u7684\u6a21\u578b</li> <li>\u521b\u4e1a\u8fc7\u7a0b\u7684\u4e09\u8981\u7d20</li> <li>\u521b\u4e1a\u5931\u8d25\u7684\u5185\u5916\u90e8\u56e0\u7d20</li> <li>\u521b\u4e1a\u5b66\u4e60\u7684\u5173\u952e</li> </ol> </li> <li>\u7b2c1\u7ae0 \u521b\u4e1a\u4e0e\u521b\u4e1a\u7cbe\u795e     <ol> <li>\u521b\u4e1a\u7684\u6982\u5ff5\u548c\u7c7b\u578b</li> <li>\u521b\u4e1a\u3001\u521b\u4e1a\u7cbe\u795e\u4e0e\u7ecf\u6d4e\u589e\u957f</li> <li>\u521b\u4e1a\u7cbe\u795e\u4e0e\u793e\u4f1a\u53d1\u5c55</li> <li>\u521b\u4e1a\u73af\u5883</li> <li>\u521b\u4e1a\u6559\u80b2</li> </ol> </li> <li>\u7b2c2\u7ae0 \u521b\u4e1a\u8fc7\u7a0b     <ol> <li>\u7406\u89e3\u521b\u4e1a\u7684\u4e00\u822c\u8fc7\u7a0b</li> <li>\u65b0\u521b\u4f01\u4e1a\u7684\u751f\u547d\u5468\u671f</li> <li>\u521b\u4e1a\u4e2d\u6240\u9700\u7684\u8d44\u6e90</li> <li>\u7cbe\u76ca\u521b\u4e1a\u7684\u7406\u5ff5\u548c\u601d\u7ef4</li> <li>\u4e09\u4e2a\u91cd\u8981\u7684\u521b\u4e1a\u6a21\u578b</li> </ol> </li> <li>\u7b2c3\u7ae0 \u521b\u4e1a\u673a\u4f1a     <ol> <li>\u521b\u4e1a\u673a\u4f1a\uff1a\u6982\u5ff5\u548c\u5b58\u5728\u7684\u539f\u56e0</li> <li>\u521b\u4e1a\u673a\u4f1a\u7684\u671f\u671b\u4ef7\u503c\uff1a\u9009\u62e9\u5229\u4e8e\u521b\u4e1a\u7684\u673a\u4f1a</li> <li>\u521b\u4e1a\u673a\u4f1a\u8bc4\u4ef7</li> <li>\u521b\u4e1a\u673a\u4f1a\u8bc6\u522b\u4e0e\u5f00\u53d1</li> </ol> </li> <li>\u7b2c4\u7ae0 \u5546\u4e1a\u6a21\u5f0f     <ol> <li>\u5546\u4e1a\u6a21\u5f0f\u7684\u6982\u5ff5</li> <li>\u5546\u4e1a\u6a21\u5f0f\u7684\u4f5c\u7528</li> <li>\u5546\u4e1a\u6a21\u5f0f\u7684\u8bc4\u4ef7</li> <li>\u5546\u4e1a\u6a21\u5f0f\u7684\u6f14\u8fdb\u548c\u6301\u7eed\u521b\u65b0</li> </ol> </li> <li>\u7b2c5\u7ae0 \u521b\u4e1a\u8005\u4e0e\u521b\u4e1a\u56e2\u961f     <ol> <li>\u521b\u4e1a\u8005\u5fc3\u7406\u53ca\u6027\u683c\u7279\u8d28</li> <li>\u521b\u4e1a\u8005\u5e94\u5177\u5907\u7684\u4e2a\u4eba\u80fd\u529b</li> <li>\u521b\u4e1a\u56e2\u961f\u7684\u7ec4\u5efa</li> <li>\u521b\u4e1a\u56e2\u961f\u7684\u80a1\u6743\u5206\u914d\u548c\u6fc0\u52b1</li> </ol> </li> <li>\u7b2c6\u7ae0 \u5546\u4e1a\u8ba1\u5212     <ol> <li>\u5546\u4e1a\u8ba1\u5212</li> <li>\u5982\u4f55\u5236\u5b9a\u5546\u4e1a\u8ba1\u5212\u4e66</li> <li>\u5546\u4e1a\u8ba1\u5212\u4e66\u7684\u4e3b\u8981\u5185\u5bb9</li> <li>\u5546\u4e1a\u8ba1\u5212\u4e66\u4e2d\u7684\u4e00\u4e9b\u5e38\u89c1\u95ee\u9898</li> </ol> </li> <li>\u7b2c7\u7ae0 \u521b\u4e1a\u878d\u8d44     <ol> <li>\u521b\u4e1a\u878d\u8d44\u96be\u7684\u539f\u56e0\u548c\u521b\u4e1a\u8005\u7684\u57fa\u672c\u5bf9\u7b56\u5206\u6790</li> <li>\u521b\u4e1a\u878d\u8d44\u7684\u8d44\u91d1\u9700\u6c42</li> <li>\u521b\u4e1a\u878d\u8d44\u7684\u4e3b\u8981\u65b9\u5f0f\u548c\u878d\u8d44\u8def\u5f84</li> <li>\u521b\u4e1a\u4f01\u4e1a\u7684\u4ef7\u503c\u8bc4\u4f30</li> <li>\u521b\u4e1a\u878d\u8d44\u548c\u521b\u4e1a\u6295\u8d44\u7684\u7b56\u7565</li> </ol> </li> </ol>"},{"location":"zju/general_courses/entrepreneurship/#\u6210\u7ee9\u6784\u6210","title":"\u6210\u7ee9\u6784\u6210","text":""},{"location":"zju/general_courses/entrepreneurship/#\u7ebf\u4e0a\u5b66\u4e60\u90e8\u520640\u5206","title":"\u7ebf\u4e0a\u5b66\u4e60\u90e8\u5206\uff0840\u5206\uff09","text":"<p>\u7ebf\u4e0a\u5b66\u4e60\u7a7a\u95f4\uff1a\u5b66\u5802\u5728\u7ebf\u3001\u6d59\u5927\u96e8\u8bfe\u5802</p>"},{"location":"zju/general_courses/entrepreneurship/#\u7ebf\u4e0a\u89c2\u770b\u89c6\u989130","title":"\u7ebf\u4e0a\u89c2\u770b\u89c6\u9891\uff0830%\uff09","text":"<p>\u5efa\u8bae\u5728\u624b\u673a\u7aef\u5237\u89c6\u9891\uff0c\u624b\u673a\u4e0a\u53ef\u4ee5\u89c6\u9891\u8fde\u64ad</p> \u788e\u788e\u5ff5 <p>\u671f\u672b\u8003\u8bd5\u5185\u5bb9\u548c\u7ebf\u4e0a\u89c6\u9891\u5185\u5bb9\u65e0\u5173 (1)</p> <ol> <li>\u5e94\u8be5\u65e0\u5173\u5427\uff0c\u53cd\u6b63\u6211\u6ca1\u542c\uff08\u5c0f\u58f0\uff09</li> </ol>"},{"location":"zju/general_courses/entrepreneurship/#\u7ebf\u4e0a\u6d4b\u8bd5\u6216\u5355\u5143\u8003\u683820","title":"\u7ebf\u4e0a\u6d4b\u8bd5\u6216\u5355\u5143\u8003\u6838\uff0820%\uff09","text":"<p>\u53ea\u6709\u4e00\u6b21\u7b54\u9898\u673a\u4f1a</p> <p>\u6d4b\u8bd5\u9898\u7b54\u6848\uff1a</p> <p></p>"},{"location":"zju/general_courses/entrepreneurship/#\u8ba8\u8bba20","title":"\u8ba8\u8bba\uff0820%\uff09","text":""},{"location":"zju/general_courses/entrepreneurship/#\u7ebf\u4e0a\u5927\u4f5c\u4e1a30","title":"\u7ebf\u4e0a\u5927\u4f5c\u4e1a\uff0830%\uff09","text":"<p>\u5199\u4e00\u4efd\u5546\u4e1a\u8ba1\u5212\u4e66</p> \u788e\u788e\u5ff5 <p>\u6211\u5728\u5199\u7684\u65f6\u5019\u611f\u89c9\u5341\u5206\u75db\u82e6 /(\u3112o\u3112)/~~</p>"},{"location":"zju/general_courses/entrepreneurship/#\u8bb2\u5ea7\u90e8\u520620\u5206","title":"\u8bb2\u5ea7\u90e8\u5206\uff0820\u5206\uff09","text":"<p>\u81f3\u5c11\u542c\u4e24\u573a\u7ebf\u4e0a\u8bb2\u5ea7\uff0c\u5199\u4e00\u7bc7\u4e0d\u5c11\u4e8e2000\u5b57\u7684\u542c\u540e\u611f\u62a5\u544a</p>"},{"location":"zju/general_courses/entrepreneurship/#\u671f\u672b\u8003\u8bd540\u5206","title":"\u671f\u672b\u8003\u8bd5\uff0840\u5206\uff09","text":"<p>\u95ed\u5377\u8003\u8bd5</p> \u788e\u788e\u5ff5 <p>\u770b\u4e86\u4e4b\u524d\u7684\u5386\u5e74\u9898\uff0c\u8fd9\u4e2a\u671f\u672b\u8003\u8bd5\u5b83\u771f\u7684\uff0c\u6211\u54ed\u6b7b\uff0c\u6ca1\u6709\u91cd\u70b9\uff0c\u5168\u662f\u8003\u70b9\uff0c\u751a\u81f3\u4e66\u4e0a\u7684\u4e13\u680f\u90e8\u5206\u90fd\u8003\uff08\u4e0d\u8fc7\u786e\u5b9e\u6709\u4e9b\u8003\u70b9\u8fd8\u662f\u53cd\u590d\u51fa\u73b0\u7684\uff09</p>"},{"location":"zju/general_courses/entrepreneurship/#\u8003\u8bd5\u8303\u56f4","title":"\u8003\u8bd5\u8303\u56f4","text":"<p>\u6559\u6750 1~7 \u7ae0\uff08\u7eea\u8bba\u597d\u50cf\u4e5f\u4f1a\u8003\uff09</p>"},{"location":"zju/general_courses/entrepreneurship/#\u8003\u8bd5\u9898\u578b","title":"\u8003\u8bd5\u9898\u578b","text":"\u9009\u62e9\u9898 \u5224\u65ad\u9898 \u8bba\u8ff0\u9898 60% 20% 20% 30\u9053\u9898 10\u9053\u9898 1\u9053\u9898"},{"location":"zju/general_courses/entrepreneurship/#\u4e2a\u4eba\u611f\u53d7","title":"\u4e2a\u4eba\u611f\u53d7","text":"<p>\u770b\u60c5\u51b5\uff0c\u4e0d\u5efa\u8bae\u9009\u8fd9\u95e8\u8bfe\uff0c\u8981\u5199\u4e00\u5927\u5806\u4e1c\u897f\uff0c\u671f\u672b\u8003\u8bd5\u4e5f\u8981\u80cc\u4e00\u5927\u5806\u4e1c\u897f</p> \u788e\u788e\u5ff5 <p>\u6839\u636e\u8bfe\u672c\u5185\u5bb9\uff0c\u521b\u65b0\u521b\u4e1a\u6559\u80b2\u7684\u672c\u8d28\u610f\u4e49\u662f\uff1a</p> <ol> <li>\u6fc0\u53d1\u4eba\u7684\u4e3b\u52a8\u6027\u548c\u521b\u9020\u6027</li> <li>\u63d0\u5347\u521b\u4e1a\u8005\u7684\u8ba4\u77e5\u6c34\u5e73\u548c\u521b\u65b0\u521b\u4e1a\u6280\u80fd</li> <li>\u57f9\u80b2\u4f01\u4e1a\u5bb6\u7cbe\u795e\u548c\u56e2\u961f\u7cbe\u795e</li> </ol> <p>\u4e0d\u8fc7\u6211\u611f\u89c9\u6211\u5728\u8fd9\u95e8\u8bfe\u91cc\u4ec0\u4e48\u90fd\u6ca1\u5b66\u5230\uff0c\u5c31\u80cc\u4e86\u4e00\u5806\u8003\u8bd5\u8981\u8003\u7684\u4e1c\u897f\u800c\u5df2\u2026\u2026</p>"},{"location":"zju/general_courses/entrepreneurship/#\u7b14\u8bb0","title":"\u7b14\u8bb0","text":""},{"location":"zju/general_courses/entrepreneurship/#\u4e2a\u4eba\u7b14\u8bb0","title":"\u4e2a\u4eba\u7b14\u8bb0","text":"<p>\u4e2a\u4eba\u7b14\u8bb0\u7684\u5e16\u5b50\uff1a2023-2024\u590f \u521b\u4e1a\u542f\u7a0b \u671f\u672b\u590d\u4e60\u6574\u7406\uff08\u7eea\u8bba+1-7\u7ae0\uff09</p> <p>\u6709\u4e9b\u5185\u5bb9\u8bfb\u4e00\u8bfb\uff0c\u6709\u5370\u8c61\u5c31\u884c\uff0c\u6709\u4e9b\u5185\u5bb9\u8981\u80cc\uff08\u8fd8\u597d\u6ca1\u6709\u586b\u7a7a\u9898\uff09</p> \u8003\u8bd5\u540e <p>\u554a\u54c8\u54c8\uff0c\u6211\u6574\u7406\u7684\u8d44\u6599\u8fd8\u662f\u633a\u5168\u7684\uff0c\u6211\u5df2\u77e5\u7684\u5386\u5e74\u9898\u91cc\u6ca1\u6709\u51fa\u73b0\u7684\u8003\u70b9\u4e5f\u6574\u7406\u5230\u4e86\uff08\u5982\u679c\u6ca1\u8bb0\u9519\u7684\u8bdd\uff09\uff0c\u6bd4\u5982\u521b\u610f\u662f\u521b\u4e1a\u8005\u8fdb\u5165\u521b\u4e1a\u7684\u8d77\u70b9\uff0c \u8d22\u52a1\u8ba1\u5212\u662f\u5546\u4e1a\u8ba1\u5212\u7684\u6838\u5fc3\u548c\u7075\u9b42\uff0c\u798f\u5229\u7ecf\u6d4e\u5b66\u89e3\u91ca\u4e2d\u521b\u4e1a\u673a\u4f1a\u7684\u56db\u4e2a\u6765\u6e90\uff08\u4f46\u662f\u8fd9\u4e2a\u6211\u9519\u4e86\u563b\u563b\uff0c\u6ca1\u529e\u6cd5\u8fd9\u4e2a\u9898\u8003\u5f97\u592a\u7ec6\u4e86\uff09\uff0c\u521b\u4e1a\u6295\u8d44\u5bb6\u5728\u5177\u4f53\u5206\u6790\u67d0\u4e2a\u521b\u4e1a\u4f01\u4e1a\u662f\u5426\u503c\u5f97\u6295\u8d44\u65f6\uff0c\u8003\u8651\u7684\u4e09\u4e2a\u65b9\u9762\u2026\u2026</p> <p>\u6ce8\u610f</p> <p>\u6709\u4e9b\u65b9\u9762\u6ca1\u6709\u6574\u7406\u5230\uff0c\u76ee\u524d\u5df2\u77e5\u7684\u6709\uff1a</p> <ol> <li>\u521b\u4e1a\u7c7b\u578b\uff1a\u521b\u65b0\u578b\u521b\u4e1a\uff0c\u81ea\u4e3b\u578b\u521b\u4e1a\u4ec0\u4e48\u7684\uff08\u8fd9\u4e2a\u6211\u8bb0\u5f97\u5728\u54ea\u770b\u5230\u8fc7\uff0c\u4f46\u662f\u6574\u7406\u7684\u65f6\u5019\u7ffb\u4e66\u6b7b\u6d3b\u627e\u4e0d\u5230\uff0c\u5c31\u5ffd\u7565\u4e86\uff0c\u4f46\u662f\u8003\u8bd5\u8003\u5230\u4e86\uff09</li> <li>\u4f01\u4e1a\u5728\u56db\u4e2a\u9636\u6bb5\u7684\u5404\u79cd\u7279\u5f81\u6ca1\u6709\u6574\u7406\u5b8c\u5168\uff0c\u6bd4\u5982\u4f01\u4e1a\u7b2c\u4e00\u6b21\u9047\u5230\u5de8\u5927\u6311\u6218\u662f\u4ec0\u4e48\u9636\u6bb5\uff0c\u9047\u5230\u521b\u65b0\u963b\u788d\u4e4b\u7c7b\u7684\u662f\u4ec0\u4e48\u9636\u6bb5</li> </ol> <p></p>"},{"location":"zju/general_courses/entrepreneurship/#\u5176\u5b83","title":"\u5176\u5b83","text":"<p>\u6d59\u6c5f\u5927\u5b66\u8bfe\u7a0b\u653b\u7565\u5171\u4eab\u8ba1\u5212 - \u521b\u4e1a\u542f\u7a0b</p>"},{"location":"zju/general_courses/entrepreneurship/#\u5386\u5e74\u9898\u6574\u7406","title":"\u5386\u5e74\u9898\u6574\u7406","text":"<p>\u6ce8\u610f</p> <p>\u5386\u5e74\u9898\u6574\u7406\u8d44\u6599\u5747\u6765\u81ea\u4e8e \u6d59\u6c5f\u5927\u5b66cc98\u8bba\u575b</p>"},{"location":"zju/general_courses/entrepreneurship/#2022-2023-\u590f","title":"2022-2023 \u590f","text":"<p>2022\u20142023\u590f\u5b66\u671f\u521b\u4e1a\u542f\u7a0b\u56de\u5fc6\u5377</p>"},{"location":"zju/general_courses/entrepreneurship/#2022-2023-\u51ac","title":"2022-2023 \u51ac","text":""},{"location":"zju/general_courses/entrepreneurship/#2021-2022-\u590f","title":"2021-2022 \u590f","text":"<p>\u521b\u4e1a\u542f\u7a0b\u56de\u5fc6\u5377</p>"},{"location":"zju/general_courses/entrepreneurship/#2019-2020-\u590f","title":"2019-2020 \u590f","text":""},{"location":"zju/general_courses/entrepreneurship/#2019-2020-\u79cb","title":"2019-2020 \u79cb","text":""},{"location":"zju/general_courses/phy_exp/","title":"\u5927\u5b66\u7269\u7406\u5b9e\u9a8c","text":"<p>\u8bf4\u660e</p> <p>\u6b64\u6587\u6863\u6b63\u5728\u66f4\u65b0\u4e2d\u2026\u2026</p>"},{"location":"zju/general_courses/phy_exp/#\u8bfe\u7a0b\u4ecb\u7ecd","title":"\u8bfe\u7a0b\u4ecb\u7ecd","text":"<p>\u6ce8\u610f</p> <p>\u6b64\u4e3a 2024-2025 \u79cb\u51ac\u5b66\u671f\u8bfe\u7a0b\u5b89\u6392\uff0c\u4ec5\u4f9b\u53c2\u8003</p> <p>xt\u8001\u5e08</p>"},{"location":"zju/general_courses/phy_exp/#\u8bfe\u7a0b\u987b\u77e5","title":"\u8bfe\u7a0b\u987b\u77e5","text":""},{"location":"zju/general_courses/phy_exp/#\u6211\u7684\u8bfe\u8868","title":"\u6211\u7684\u8bfe\u8868","text":"\u5b9e\u9a8c\u540d\u79f0 \u6307\u5bfc\u6559\u5e08 \u64cd\u4f5c\u96be\u6613\u7a0b\u5ea6 \u8bf4\u660e \u5f97\u5206 \u4e07\u7528\u8868\u7684\u8bbe\u8ba1 pbl\u8001\u5e08 \u7b80\u5355\u8d39\u65f6\u5c11 98 \u4ea4\u6d41\u7535\u8def\u529f\u7387\u56e0\u6570\u5b9e\u9a8c\u25b2\u5f17\u5170\u514b\u8d6b\u5179\u5b9e\u9a8c lyh\u8001\u5e08 \u7b80\u5355\u8d39\u65f6\u5c11 1. \u540c\u65f6\u505a\u4e24\u4e2a\u5b9e\u9a8c2. \u4e24\u4efd\u5b9e\u9a8c\u62a5\u544a\u8981\u5206\u5f00\u51993. \u4ea4\u6d41\u7535\u8def\u8001\u5e08\u5df2\u7ecf\u642d\u597d\u4e86\uff0c\u53ea\u9700\u8981\u6309\u5f00\u5173\uff0c\u8bb0\u5f55\u6570\u636e\u5373\u53ef \u5206\u5149\u8ba1\u7684\u8c03\u6574\u548c\u4f7f\u7528 jll\u8001\u5e08 \u4e2d\u7b49\u8d39\u65f6\u4e2d\u7b49 1. \u5fc5\u505a \u5b9e\u9a8c2. \u5982\u679c\u4e66\u4e0a\u7684\u64cd\u4f5c\u770b\u4e0d\u61c2\uff0c\u53ef\u4ee5\u53bbB\u7ad9\u641c\u89c6\u9891 \u793a\u6ce2\u5668\u7684\u5e94\u7528 yjm\u8001\u5e08 \u5fc5\u505a \u5b9e\u9a8c \u53cc\u68f1\u955c\u5e72\u6d89 ylm\u8001\u5e08 \u5bc6\u7acb\u6839\u6cb9\u6ef4\u5b9e\u9a8c pbl\u8001\u5e08 \u68f1\u955c\u504f\u5411\u89d2\u7279\u6027 ylm\u8001\u5e08 \u987b\u5148\u505a\u201c\u5206\u5149\u8ba1\u7684\u8c03\u6574\u548c\u4f7f\u7528\u201d\u5b9e\u9a8c \u25b2\u666e\u6717\u514b\u5e38\u6570 lyh\u8001\u5e08 \u65cb\u8f6c\u6db2\u4f53\u7efc\u5408\u5b9e\u9a8c yhc\u8001\u5e08 \u52a8\u6001\u6cd5\u6d4b\u91cf\u6750\u6599\u6768\u6c0f\u6a21\u91cf zl\u8001\u5e08 \u7a7a\u6c14\u5bc6\u5ea6\u6d4b\u91cf yhc\u8001\u5e08 \u7528\u53cc\u81c2\u7535\u6865\u6d4b\u4f4e\u7535\u963b dxy\u8001\u5e08 \u975e\u5e73\u8861\u7535\u6865 dxy\u8001\u5e08 \u60e0\u65af\u767b\u7535\u6865 dxy\u8001\u5e08"},{"location":"zju/general_courses/phy_exp/#\u6211\u7684\u5b9e\u9a8c\u62a5\u544a","title":"\u6211\u7684\u5b9e\u9a8c\u62a5\u544a","text":""},{"location":"zju/general_courses/radio_direction_finding/","title":"\u65e0\u7ebf\u7535\u6d4b\u5411\uff08\u521d\u7ea7\uff09","text":""},{"location":"zju/general_courses/radio_direction_finding/#\u8bfe\u7a0b\u4ecb\u7ecd","title":"\u8bfe\u7a0b\u4ecb\u7ecd","text":"<p>\u6ce8\u610f</p> <p>\u6b64\u4e3a 2023-2024 \u79cb\u51ac \u548c 2024-2025 \u79cb\u51ac\u5b66\u671f\u8bfe\u7a0b\u5b89\u6392\uff0c\u4ec5\u4f9b\u53c2\u8003</p> <p>dyp\u8001\u5e08 / zl\u8001\u5e08 (1)</p> <ol> <li>\u6211\u62a5\u4e86\u4e24\u6b21\u8fd9\u4e2a\u8bfe\uff0c\u4e24\u6b21\u8bfe\u7684\u8001\u5e08\u62a5\u7684\u4e0d\u4e00\u6837</li> </ol> <p>\u65e0\u7ebf\u7535\u53f0\u6563\u843d\u5728\u5404\u4e2a\u5730\u65b9\uff0c\u9700\u8981\u4f7f\u7528\u65e0\u7ebf\u7535\u6d4b\u5411\u673a\u627e\u5230\u8fd9\u4e9b\u7535\u53f0\uff0c\u64cd\u4f5c\u8d77\u6765\u975e\u5e38\u7684\u7b80\u5355\uff0c\u4f46\u662f\u627e\u8d77\u6765\u53ef\u80fd\u6709\u4e9b\u96be\u5ea6</p>"},{"location":"zju/general_courses/radio_direction_finding/#\u8003\u6838\u65b9\u5f0f","title":"\u8003\u6838\u65b9\u5f0f","text":"<p>\u8bf4\u660e</p> <p>\u4f53\u6d4b\u3001\u7406\u8bba\u8003\u8bd5\u7b49\u5176\u5b83\u5185\u5bb9\u7701\u7565</p>"},{"location":"zju/general_courses/radio_direction_finding/#\u542c\u53f0\u8003\u8bd5","title":"\u542c\u53f0\u8003\u8bd5","text":"<p>\u4e00\u5171\u6709 11 \u4e2a\u53f0\uff0c\u6bcf\u4e2a\u53f0\u5bf9\u5e94\u4e00\u79cd\u7535\u7801 (1) \uff0c\u4e00\u6bb5\u65f6\u95f4\u5185\u968f\u673a\u5207\u6362\u53f0\u53f7\uff0c\u9700\u8981\u4f7f\u7528\u65e0\u7ebf\u7535\u6d4b\u5411\u673a\u542c\u51fa\u662f\u54ea\u4e00\u4e2a\u53f0\u53f7</p> <ol> <li>\u7c7b\u4f3c\u4e8e\u6469\u65af\u7535\u7801</li> </ol> \u788e\u788e\u5ff5 <p>\u542c\u53f0\u8003\u8bd5\u5f88\u7b80\u5355\u7684\uff0c\u4e0d\u8981\u7d27\u5f20\u5c31\u884c</p>"},{"location":"zju/general_courses/radio_direction_finding/#\u5b9e\u8df5\u627e\u53f0","title":"\u5b9e\u8df5\u627e\u53f0","text":"<p>4 \u6b21\u5b9e\u8df5\u627e\u53f0\u8003\u8bd5\uff0c2 \u6b21\u5728\u7d2b\u91d1\u6e2f\u6821\u533a\uff0c\u53e6\u5916 2 \u6b21\u5728\u5176\u5b83\u6821\u533a\u3002\u53d6 2 \u6b21\u6700\u597d\u7684\u6210\u7ee9</p> <p>\u5f00\u59cb\u65f6\u7ed9\u4f60\u4e00\u4e2a\u5361\u7247\uff0c\u4e0a\u9762\u662f\u4f60\u9700\u8981\u627e\u7684\u53f0\u53f7\uff0c\u4e00\u5171 10 \u4e2a\u53f0 (1) \uff0c\u4f60\u9700\u8981\u627e 5 \u4e2a\u3002\u627e\u5230\u540e\uff0c\u7535\u53f0\u90a3\u91cc\u6709\u7ed9\u5361\u7247\u76f8\u5e94\u4f4d\u7f6e\u505a\u6807\u8bb0 (3) \u7684\u5de5\u5177\u3002\u5168\u90e8\u627e\u5b8c\u518d\u8fd4\u56de\u8d77\u70b9\uff08\u7ec8\u70b9\uff09\u5373\u53ef\uff0c\u6839\u636e\u4f60\u6240\u7528\u7684\u65f6\u95f4\u548c\u627e\u5230\u53f0\u7684\u6570\u91cf (2) \u8fdb\u884c\u6392\u540d</p> <ol> <li>MO \u53f0\u4e0d\u9700\u8981\u627e\uff0cMO \u53f0\u7684\u4f5c\u7528\u662f\u544a\u8bc9\u4f60\u8d77\u70b9\u548c\u7ec8\u70b9\u5728\u54ea\u91cc\uff0c\u6211\u4eec\u8fd9\u95e8\u8bfe\u8d77\u70b9\u548c\u7ec8\u70b9\u5728\u540c\u4e00\u4e2a\u4f4d\u7f6e</li> <li>\u56e0\u4e3a\u4f60\u53ef\u80fd\u627e\u9519\u53f0\u4e86</li> <li>\u6bcf\u4e2a\u53f0\u7684\u6807\u8bb0\u4e0d\u4e00\u6837\uff0c\u7528\u4e8e\u68c0\u67e5\u4f60\u7684\u53f0\u6709\u6ca1\u6709\u627e\u5bf9</li> </ol> \u788e\u788e\u5ff5 <p>\u53ef\u4ee5\u76f8\u4e92\u5e2e\u52a9\u54e6\uff08\u5c0f\u58f0\uff09</p>"},{"location":"zju/general_courses/radio_direction_finding/#\u4e2a\u4eba\u611f\u53d7","title":"\u4e2a\u4eba\u611f\u53d7","text":"<p>\u5f88\u6709\u610f\u601d\u7684\u4e00\u95e8\u8bfe\u5440</p>"},{"location":"zju/general_courses/tea_culture/","title":"\u8336\u6587\u5316\u4e0e\u8336\u5065\u5eb7","text":""},{"location":"zju/general_courses/tea_culture/#\u8bfe\u7a0b\u4ecb\u7ecd","title":"\u8bfe\u7a0b\u4ecb\u7ecd","text":"<p>\u6ce8\u610f</p> <p>\u6b64\u4e3a 2023-2024 \u79cb\u51ac\u5b66\u671f\u8bfe\u7a0b\u5b89\u6392\uff0c\u4ec5\u4f9b\u53c2\u8003</p> <p>wyf\u8001\u5e08 hpm\u8001\u5e08 (1) </p> <ol> <li>wyf\u8001\u5e08\u4e0a\u8bfe\u4f1a\u5e26\u5c0f\u793c\u7269</li> </ol> <p>\u6709\u7406\u8bba\u8bfe\uff0c\u7ebf\u4e0a\u5b66\u4e60\uff0c\u8ba8\u8bba\u8bfe\uff0c\u4f53\u9a8c\u8bfe</p> <p>\u7406\u8bba\u8bfe\u8bb2\u8336\u7684\u76f8\u5173\u77e5\u8bc6\u548c\u6709\u5173\u5065\u5eb7\u7684\u77e5\u8bc6\uff1b\u8ba8\u8bba\u8bfe\u662f\u52a9\u6559\u5e26\u7740\u5b66\u751f\u4e0a\u8bfe\uff0c\u57fa\u672c\u4e0a\u53ef\u4ee5\u5728\u4e0b\u9762\u5e72\u81ea\u5df1\u7684\u4e8b\u60c5\uff1b\u4f53\u9a8c\u8bfe\u8001\u5e08\u5e26\u7740\u4f60\u6ce1\u8336\u559d\u8336</p>"},{"location":"zju/general_courses/tea_culture/#\u8bfe\u7a0b\u7c7b\u522b","title":"\u8bfe\u7a0b\u7c7b\u522b","text":"<p>\u4e2d\u534e\u4f20\u7edf \u901a\u8bc6\u6838\u5fc3\u8bfe\u7a0b</p>"},{"location":"zju/general_courses/tea_culture/#\u8bfe\u7a0b\u5185\u5bb9","title":"\u8bfe\u7a0b\u5185\u5bb9","text":""},{"location":"zju/general_courses/tea_culture/#\u7406\u8bba\u8bfe","title":"\u7406\u8bba\u8bfe","text":""},{"location":"zju/general_courses/tea_culture/#\u8336\u76f8\u5173","title":"\u8336\u76f8\u5173","text":"<ol> <li>\u6d59\u6c5f\u5927\u5b66\u8336\u5b66\u5386\u53f2</li> <li>\u8336\u7684\u8d77\u6e90\u4e0e\u5f71\u54cd<ol> <li>\u8336\u4e3a\u4f55\u7269</li> <li>\u8336\u4e4b\u8d77\u6e90</li> <li>\u8336\u4e4b\u5f71\u54cd</li> </ol> </li> <li>\u4e2d\u56fd\u8336\u4ea7\u4e1a\u53d1\u5c55\u72b6\u51b5</li> <li>\u8336\u53f6\u54c1\u8d28\u6210\u5206\u5316\u5b66<ol> <li>\u8336\u53f6\u4e2d\u7684\u5316\u5b66\u6210\u5206\u4e0e\u7279\u5f81</li> <li>\u4e2d\u56fd\u8336\u53f6\u5206\u7c7b\u4e0e\u539f\u7406</li> <li>\u73af\u5883\u56e0\u5b50\u5bf9\u8336\u53f6\u54c1\u8d28\u7684\u5f71\u54cd</li> </ol> </li> <li>\u8336\u53f6\u4fdd\u5065\u4f5c\u7528\u4e0e\u79d1\u5b66\u996e\u8336<ol> <li>\u8336\u591a\u529f\u6548\u7684\u7406\u8bba\u4f9d\u636e</li> <li>\u8336\u7684\u4fdd\u5065\u529f\u6548\u4e0e\u8336\u5065\u5eb7\u6700\u65b0\u7814\u7a76\u8fdb\u5c55</li> <li>\u79d1\u5b66\u996e\u8336</li> </ol> </li> <li>\u8bc6\u8336\u6ce1\u8336</li> </ol>"},{"location":"zju/general_courses/tea_culture/#\u5065\u5eb7\u76f8\u5173","title":"\u5065\u5eb7\u76f8\u5173","text":"<ol> <li>\u5065\u5eb7</li> <li>\u516d\u5927\u8425\u517b\u7d20</li> <li>\u7cd6\u5c3f\u75c5</li> <li>\u80a5\u80d6</li> <li>\u9ad8\u8840\u538b</li> </ol>"},{"location":"zju/general_courses/tea_culture/#\u7ebf\u4e0a\u5b66\u4e60","title":"\u7ebf\u4e0a\u5b66\u4e60","text":"<p>\u89c2\u770b\u6307\u5b9a\u7684\u89c6\u9891\u5373\u53ef\uff0c\u6ca1\u6709\u7ebf\u4e0a\u6d4b\u8bd5\uff0c\u89c6\u9891\u5185\u5bb9\u4e5f\u4e0e\u671f\u672b\u8003\u8bd5\u65e0\u5173\uff0c\u611f\u5174\u8da3\u7684\u53ef\u4ee5\u770b\u4e00\u770b</p>"},{"location":"zju/general_courses/tea_culture/#\u8ba8\u8bba\u8bfe","title":"\u8ba8\u8bba\u8bfe","text":"<p>2 \u6b21\u5c0f\u7ec4\u5c55\u793a\uff0c1 \u6b21\u4e2a\u4eba\u5c55\u793a</p> <p>\u5176\u5b83\u65f6\u95f4\u52a9\u6559\u53ef\u80fd\u8bb2\u4e00\u4e9b\u6709\u5173\u8336\u7684\u5c0f\u77e5\u8bc6\uff0c\u653e\u4e00\u4e9b\u6709\u5173\u8336\u7684\u77ed\u7247</p>"},{"location":"zju/general_courses/tea_culture/#\u4f53\u9a8c\u8bfe","title":"\u4f53\u9a8c\u8bfe","text":"<p>\u4f53\u9a8c\u5b66\u4e60\u8336\u7684\u6ce1\u6cd5\u548c\u793c\u4eea</p>"},{"location":"zju/general_courses/tea_culture/#\u8003\u6838\u65b9\u5f0f","title":"\u8003\u6838\u65b9\u5f0f","text":""},{"location":"zju/general_courses/tea_culture/#\u8ba8\u8bba\u8bfe\u5c55\u793a","title":"\u8ba8\u8bba\u8bfe\u5c55\u793a","text":"<p>3 \u6b21\u5c55\u793a</p>"},{"location":"zju/general_courses/tea_culture/#\u5c0f\u8bba\u6587","title":"\u5c0f\u8bba\u6587","text":"<p>\u8bba\u6587\u4e3b\u9898\uff1a\u8336\u7684\u672a\u6765</p>"},{"location":"zju/general_courses/tea_culture/#\u671f\u672b\u8003\u8bd5","title":"\u671f\u672b\u8003\u8bd5","text":""},{"location":"zju/general_courses/tea_culture/#\u8003\u8bd5\u5f62\u5f0f","title":"\u8003\u8bd5\u5f62\u5f0f","text":"<p>\u95ed\u5377\u8003\u8bd5</p> \u788e\u788e\u5ff5 <p>\u867d\u7136\u662f\u95ed\u5377\u8003\u8bd5\uff0c\u4f46\u662f\u611f\u89c9\u6bd4\u5176\u4ed6\u7684\u95ed\u5377\u8003\u8bd5\u7684\u5185\u5bb9\u8981\u597d\u80cc\u5f88\u591a</p>"},{"location":"zju/general_courses/tea_culture/#\u8003\u8bd5\u5185\u5bb9","title":"\u8003\u8bd5\u5185\u5bb9","text":"<p>\u8001\u5e08\u6700\u540e\u51e0\u8282\u8bfe\u4f1a\u7ed9\u51fa\u8003\u8bd5\u5927\u7eb2</p> <p>\u6ce8\u610f</p> <p>\u8001\u5e08\u4e0a\u8bfe\u8bf4\uff0c\u6bcf\u5b66\u671f\u4ed6\u7ed9\u7684\u8003\u8bd5\u5927\u7eb2\u90fd\u4e0d\u4e00\u6837</p>"},{"location":"zju/general_courses/tea_culture/#\u4e2a\u4eba\u611f\u53d7","title":"\u4e2a\u4eba\u611f\u53d7","text":"<p>\u867d\u7136\u6700\u540e\u7ee9\u70b9\u53ea\u6709 4.2\uff0c\u4f46\u662f\u6574\u4f53\u611f\u89c9\u8fd8\u662f\u975e\u5e38\u6109\u5feb\u7684</p>"},{"location":"zju/general_courses/tea_culture/#\u4e2a\u4eba\u7b14\u8bb0","title":"\u4e2a\u4eba\u7b14\u8bb0","text":"<p>\u671f\u672b\u8003\u8bd5\u6574\u7406\uff1a</p> <p></p> <p>\u5065\u5eb7\u76f8\u5173\u9898\u7eb2\uff1a</p> <p></p>"}]}